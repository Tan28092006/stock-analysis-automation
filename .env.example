# Copy this file to .env and fill in your own key.
# Do not commit .env.

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Pick the exact model id from NVIDIA Build / NIM model catalog.
# NVIDIA docs currently list Google Gemma ids such as google/gemma-2-2b-it and google/gemma-7b.
NVIDIA_MODEL=google/gemma-2-2b-it

